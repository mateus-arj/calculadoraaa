<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="20"
      style="-fx-background-color: linear-gradient(to bottom, #2b2b2b, #1a1a1a);"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.calculadoraaa.HelloController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- VISOR -->

    <TextArea fx:id="visor"
              editable="false"
              wrapText="true"
              prefWidth="350"
              prefHeight="120"
              style="
              -fx-control-inner-background: #101010;
              -fx-text-fill: white;
              -fx-font-size: 32px;
              -fx-font-weight: bold;
              -fx-background-radius: 25;
              -fx-border-radius: 25;
              -fx-border-color: #444;
              "/>

    <!-- HISTÓRICO -->

    <TextArea fx:id="historico"
              editable="false"
              prefWidth="350"
              prefHeight="120"
              style="
              -fx-control-inner-background: #181818;
              -fx-text-fill: white;
              -fx-font-size: 14px;
              -fx-background-radius: 20;
              -fx-border-radius: 20;
              -fx-border-color: #333;
              "/>

    <!-- BOTÕES -->
    <Button fx:id="modoBotao"
            text="Modo: Normal"
            onAction="#alternarModo"
            style="
        -fx-background-color: #444;
        -fx-text-fill: white;
        -fx-font-size: 16px;
        -fx-background-radius: 15;
        -fx-pref-width: 220;
        -fx-pref-height: 45;
        "/>

    <GridPane alignment="CENTER"
              hgap="12"
              vgap="12">

        <Button text="(" onAction="#parentese"
                GridPane.rowIndex="5"
                GridPane.columnIndex="0"
                style="-fx-background-color:#555; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:70;"/>

        <Button text=")" onAction="#parentese"
                GridPane.rowIndex="5"
                GridPane.columnIndex="1"
                style="-fx-background-color:#555; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:70;"/>



        <Button text="7" onAction="#numero"
                GridPane.rowIndex="0"
                GridPane.columnIndex="0"
                style="-fx-background-color:#3b3b3b; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="8" onAction="#numero"
                GridPane.rowIndex="0"
                GridPane.columnIndex="1"
                style="-fx-background-color:#3b3b3b; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="9" onAction="#numero"
                GridPane.rowIndex="0"
                GridPane.columnIndex="2"
                style="-fx-background-color:#3b3b3b; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="÷" onAction="#operacao"
                GridPane.rowIndex="0"
                GridPane.columnIndex="3"
                style="-fx-background-color:orange; -fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="4" onAction="#numero"
                GridPane.rowIndex="1"
                GridPane.columnIndex="0"
                style="-fx-background-color:#3b3b3b; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="5" onAction="#numero"
                GridPane.rowIndex="1"
                GridPane.columnIndex="1"
                style="-fx-background-color:#3b3b3b; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="6" onAction="#numero"
                GridPane.rowIndex="1"
                GridPane.columnIndex="2"
                style="-fx-background-color:#3b3b3b; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="×" onAction="#operacao"
                GridPane.rowIndex="1"
                GridPane.columnIndex="3"
                style="-fx-background-color:orange; -fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="1" onAction="#numero"
                GridPane.rowIndex="2"
                GridPane.columnIndex="0"
                style="-fx-background-color:#3b3b3b; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="2" onAction="#numero"
                GridPane.rowIndex="2"
                GridPane.columnIndex="1"
                style="-fx-background-color:#3b3b3b; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="3" onAction="#numero"
                GridPane.rowIndex="2"
                GridPane.columnIndex="2"
                style="-fx-background-color:#3b3b3b; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="-" onAction="#operacao"
                GridPane.rowIndex="2"
                GridPane.columnIndex="3"
                style="-fx-background-color:orange; -fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="0" onAction="#numero"
                GridPane.rowIndex="3"
                GridPane.columnIndex="0"
                style="-fx-background-color:#3b3b3b; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="." onAction="#decimal"
                GridPane.rowIndex="3"
                GridPane.columnIndex="1"
                style="-fx-background-color:#3b3b3b; -fx-text-fill:white; -fx-font-size:22px; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="=" onAction="#igual"
                GridPane.rowIndex="3"
                GridPane.columnIndex="2"
                style="-fx-background-color:#00b35a; -fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="+" onAction="#operacao"
                GridPane.rowIndex="3"
                GridPane.columnIndex="3"
                style="-fx-background-color:orange; -fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold; -fx-background-radius:20; -fx-pref-width:80; -fx-pref-height:80;"/>

        <Button text="C" onAction="#limpar"
                GridPane.rowIndex="4"
                GridPane.columnIndex="0"
                GridPane.columnSpan="2"
                style="-fx-background-color:#d32f2f; -fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold; -fx-background-radius:20; -fx-pref-width:172; -fx-pref-height:70;"/>

        <Button text="⌫" onAction="#apagar"
                GridPane.rowIndex="4"
                GridPane.columnIndex="2"
                GridPane.columnSpan="2"
                style="-fx-background-color:#555; -fx-text-fill:white; -fx-font-size:22px; -fx-font-weight:bold; -fx-background-radius:20; -fx-pref-width:172; -fx-pref-height:70;"/>

    </GridPane>

</VBox>